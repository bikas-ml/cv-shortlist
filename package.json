{
  "name": "cv-shortlister-dashboard",
  "version": "1.0.0",
  "description": "Professional Node.js dashboard for CV Shortlister + ATS",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev:server": "nodemon server.js",
    "dev:client": "cd client && npm run dev",
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\"",
    "build": "cd client && npm install && npm run build",
    "build:start": "npm run build && npm start"
  },
  "dependencies": {
    "@google/genai": "^1.51.0",
    "@google/generative-ai": "^0.24.1",
    "@supabase/supabase-js": "^2.105.1",
    "dotenv": "^17.3.1",
    "express": "^4.19.2",
    "multer": "^1.4.5-lts.1",
    "pdf-parse": "^1.1.4",
    "pdfkit": "^0.18.0",
    "pg": "^8.20.0"
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "nodemon": "^3.1.4"
  }
}
